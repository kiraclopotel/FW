{
  "name": "feelingwise",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered content neutralizer",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && BUILD_TARGET=content vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ --ext .ts,.tsx",
    "package": "npm run build && cd dist && zip -r ../feelingwise.zip ."
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
